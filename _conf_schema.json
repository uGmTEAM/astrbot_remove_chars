{
    "chars_to_remove": {
        "type": "string",
        "default": "*#@",
        "description": "要移除的字符（直接输入，如：*#@ 或 *, #, @）"
    },
    "remove_spaces": {
        "type": "bool",
        "default": false,
        "description": "是否移除所有空格"
    },
    "only_prefix": {
        "type": "bool",
        "default": false,
        "description": "是否只移除开头的字符"
    },
    "only_suffix": {
        "type": "bool",
        "default": false,
        "description": "是否只移除末尾的字符"
    }
}